---
import Layout from "../layouts/Layout.astro";
import S01Navigation from "../components/sections/S01Navigation.astro";
import PageHero from "../components/credo/PageHero.astro";
import AboutHospitality from "../components/credo/AboutHospitality.astro";
import AboutStats from "../components/credo/AboutStats.astro";
import TestimonialBlock from "../components/credo/TestimonialBlock.astro";
import AboutPersonal from "../components/credo/AboutPersonal.astro";
import ContactCta from "../components/credo/ContactCta.astro";
import S10Footer from "../components/sections/S10Footer.astro";
import { href } from '../lib/nav';
---

<Layout title="About Andy, Credo Financial Services">
  <S01Navigation />
  <PageHero
    bgImage="about"
    eyebrow="About Andy"
    heading="When it matters, people want a person, not a system."
    body={[
      "I'm twenty-three, navigating a container ship through a typhoon off the coast of Japan, and the only thing between us and the rocks is a compass, a chart, and whether I'd done my job properly.",
      "The Merchant Navy teaches you something that sticks, and twenty years running pubs and hotels drilled it in further. When the wheels come off, people don't want a help desk, they want someone who's been in the same boat and knows what to do.",
    ]}
  />
  <AboutHospitality />
  <AboutStats />
  <!-- Proof narrative -->
  <section class="bg-white py-16 sm:py-20">
    <div class="max-w-[1232px] mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs uppercase tracking-widest text-gray-text mb-4">Proof</p>
      <div class="w-12 h-0.5 bg-accent mb-12"></div>
      <div class="max-w-3xl">
        <p class="text-gray-text leading-relaxed mb-6">
          Sallyann Reed has been a client for five years now. When there's a better deal out there for her business, I let her know, and when something goes wrong, she calls me rather than a helpline or a chatbot queue.
        </p>
        <p class="text-gray-text leading-relaxed">
          That's how it should work, and for most of my clients it does. About 70% of the people I work with came through a recommendation from someone I'd already helped. I don't run ads or cold-call anyone. I just do the work properly and let people talk.
        </p>
      </div>
    </div>
  </section>
  <TestimonialBlock
    label="Proof"
    heading="Five years and counting"
    quote="He has always been committed to providing me with an excellent service, knowing how my business works. If there's a better package for me he'll come in and advise me to change. Peace of mind knowing that if there's an issue I can call him and it will be rectified very quickly."
    name="Sallyann Reed"
    source="Five years as a customer, TrustPilot"
  />
  <!-- Link to reviews -->
  <div class="bg-white pb-12 -mt-8">
    <div class="max-w-[1232px] mx-auto px-4 sm:px-6 lg:px-8 flex justify-center">
      <a href={href('/reviews')} class="text-sm font-semibold text-dark underline underline-offset-4 hover:text-accent transition-colors">
        Read all reviews on TrustPilot &rarr;
      </a>
    </div>
  </div>
  <AboutPersonal />
  <ContactCta
    heading="One call, and I sort it."
    subtext="Whether you're running one pub or thirty, you get the same mobile number. I'll go through your setup and tell you what I'd leave alone, what I'd change, and why, and I'm the one you ring when something goes wrong on a Friday."
    hint="No charge, no contract, just a chat."
  />
  <S10Footer />
</Layout>
