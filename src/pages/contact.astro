---
import Layout from "../layouts/Layout.astro";
import S01Navigation from "../components/sections/S01Navigation.astro";
import PageHero from "../components/credo/PageHero.astro";
import ContactMethodCards from "../components/credo/ContactMethodCards.astro";
import ContactForm from "../components/credo/ContactForm.astro";
import SocialLinks from "../components/credo/SocialLinks.astro";
import ReassuranceText from "../components/credo/ReassuranceText.astro";
import S10Footer from "../components/sections/S10Footer.astro";
---

<Layout title="Contact, Credo Financial Services">
  <S01Navigation />
  <PageHero
    bgImage="contact"
    heading="One call, and I sort it. Start here."
    body={[
      "Ring me, WhatsApp me, or drop me a line. I'll ask a few questions about your setup and give you a straight answer.",
      "I answer personally, so there's no call centre and no ticket number in the way, and you'll usually hear back from me within a few hours.",
    ]}
  />
  <ContactMethodCards />
  <ContactForm />
  <SocialLinks />
  <ReassuranceText />
  <S10Footer />
</Layout>
