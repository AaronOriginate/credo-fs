---
import Layout from "../layouts/Layout.astro";
import S01Navigation from "../components/sections/S01Navigation.astro";
import PageHero from "../components/credo/PageHero.astro";
import ConsultancyStats from "../components/credo/ConsultancyStats.astro";
import PartnersGrid from "../components/credo/PartnersGrid.astro";
import ConsultancyProcess from "../components/credo/ConsultancyProcess.astro";
import TestimonialBlock from "../components/credo/TestimonialBlock.astro";
import S22FaqAccordion from "../components/sections/S22FaqAccordion.astro";
import PatternBridge from "../components/credo/PatternBridge.astro";
import ContactCta from "../components/credo/ContactCta.astro";
import S10Footer from "../components/sections/S10Footer.astro";
---

<Layout title="Consultancy, Credo Financial Services">
  <S01Navigation />
  <PageHero
    bgImage="consultancy"
    heading="Most card machine reps don't understand your till, and that's where most of the problems start."
    body={[
      "A pub these days runs on half a dozen systems, from the till and card machine through to broadband, the booking system, and funding, all of them talking to each other. None of the reps selling you any of it can tell you how the others work.",
      "So when something goes down it's ping-pong, with the card provider blaming the till and the till blaming the card, and you end up as the one who lost the Friday night. Sound familiar?",
      "What I do is different. I've run pubs and hotels for twenty years, and I've spent the last five learning the whole setup from end to end. When we talk, we talk about all of it, and when something breaks there's one number to ring.",
    ]}
  />
  <ConsultancyStats />
  <PartnersGrid />
  <ConsultancyProcess />
  <TestimonialBlock
    quote="He has always been committed to providing me with an excellent service, knowing how my business works. If there's a better package for me he'll come in and advise me to change. Peace of mind knowing that if there's an issue I can call him and it will be rectified very quickly."
    name="Sallyann Reed"
    source="Five years as a customer, TrustPilot"
  />
  <S22FaqAccordion />
  <PatternBridge
    heading="Pubs, restaurants, cafes, bars and sports clubs, whether that's a single site or a small group."
    linkText="Book a free conversation"
    linkHref="/contact"
  />
  <ContactCta
    heading="Book a free chat."
    subtext="I'll ask a few questions about your setup, go through your statements, and give you a straight answer. If there's a better deal out there I'll find it, and if there isn't I'll tell you that, so you've lost nothing either way."
    hint="Call, WhatsApp or send a message. There's no cost and no contract."
  />
  <S10Footer />
</Layout>
