---
import Layout from "../layouts/Layout.astro";
import S01Navigation from "../components/sections/S01Navigation.astro";
import PageHero from "../components/credo/PageHero.astro";
import Narrative from "../components/credo/Narrative.astro";
import BrandGrid from "../components/credo/BrandGrid.astro";
import NavyStatement from "../components/credo/NavyStatement.astro";
import ContactCta from "../components/credo/ContactCta.astro";
import S10Footer from "../components/sections/S10Footer.astro";
---

<Layout title="Products, Credo Financial Services">
  <S01Navigation />
  <PageHero
    bgImage="products"
    eyebrow="Products"
    heading="Most of what I fit is Square, and here's why."
    subtext="There's a handful of brands I work with across tills, card machines, bookings, broadband and funding. Square is the one I end up putting in most often."
  />
  <Narrative
    paragraphs={[
      "For years the standard setup was a till from one company and a card machine from another, stuck next to each other on the bar. They didn't talk to each other. Something goes wrong, you ring one, they blame the other, you lose the afternoon.",
      "Square changed that. One box does the till and the card payment, one support line looks after the lot, and there's often no monthly rental on the hardware. The customer display screen is good enough that it closes the door on the next cold-caller trying to flog you a card machine.",
      "If Square isn't right for your setup, I'll put in something else. If what you've got already does the job, I'll tell you that and we leave it alone. I only make money when I move somebody, which is exactly why I'll say no when nothing needs moving.",
    ]}
  />
  <BrandGrid />
  <NavyStatement
    heading="Nine times out of ten, it's the broadband."
    body="Before I look at the till or the card machine, I ask about the wifi, because most of the problems I get called about aren't the kit at all, they're the connection. Card payments drop, the till locks mid-service, the kitchen printer drops offline at 7pm. Starlink has changed this for sites that can't get a proper line in, and I fit it, set it up and test it end to end, and I'm still the one you ring if it plays up."
    stats={[]}
    linkText="Ask me about Starlink"
    linkHref="/contact"
    bg="accent"
  />
  <ContactCta
    heading="Not sure what's right for you?"
    subtext="That's the whole point of ringing me first. I'll ask about your setup, what's driving you mad, and what you actually need, and then I'll tell you what I'd do. No pitch, no pressure."
    hint="Have the conversation first, then decide."
  />
  <S10Footer />
</Layout>
