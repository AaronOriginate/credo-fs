---
import { href } from '../../lib/nav';
---
<!-- Section 01 — Navigation | Figma: fileKey=RxueMLDFnpgheWZp4MVk7f nodeId=8:2 -->
<nav data-figma-ref="8:2" class="sticky top-0 z-50 bg-white border-b border-gray-200">
  <div class="max-w-[1232px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={href('/')} class="shrink-0">
        <img src="https://credofsdev.wpenginepowered.com/wp-content/uploads/2026/02/Asset-2@2x.png" alt="Credo FS" class="h-9 w-auto" />
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-8">
        <a href={href('/')} class="text-sm text-gray-text hover:text-dark transition-colors">Home</a>
        <a href={href('/about')} class="text-sm text-gray-text hover:text-dark transition-colors">About Andy</a>
        <a href={href('/consultancy')} class="text-sm font-medium text-dark">Consultancy</a>
        <a href={href('/products')} class="text-sm text-gray-text hover:text-dark transition-colors">Products</a>
        <a href={href('/reviews')} class="text-sm text-gray-text hover:text-dark transition-colors">Reviews</a>
        <a
          href={href('/contact')}
          class="bg-accent text-dark text-sm font-semibold px-5 py-2.5 rounded-full hover:brightness-95 transition-all"
        >
          Let's have a chat
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="block w-6 h-0.5 bg-dark transition-transform" id="hamburger-top"></span>
        <span class="block w-6 h-0.5 bg-dark transition-opacity" id="hamburger-mid"></span>
        <span class="block w-6 h-0.5 bg-dark transition-transform" id="hamburger-bot"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-200 bg-white">
    <div class="max-w-[1232px] mx-auto px-4 sm:px-6 py-4 flex flex-col gap-4">
      <a href={href('/')} class="text-sm text-gray-text hover:text-dark transition-colors">Home</a>
      <a href={href('/about')} class="text-sm text-gray-text hover:text-dark transition-colors">About Andy</a>
      <a href={href('/consultancy')} class="text-sm font-medium text-dark">Consultancy</a>
      <a href={href('/products')} class="text-sm text-gray-text hover:text-dark transition-colors">Products</a>
      <a href={href('/reviews')} class="text-sm text-gray-text hover:text-dark transition-colors">Reviews</a>
      <a
        href={href('/contact')}
        class="bg-accent text-dark text-sm font-semibold px-5 py-2.5 rounded-full text-center hover:brightness-95 transition-all"
      >
        Let's have a chat
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const top = document.getElementById("hamburger-top");
  const mid = document.getElementById("hamburger-mid");
  const bot = document.getElementById("hamburger-bot");

  if (btn && menu && top && mid && bot) {
    btn.addEventListener("click", () => {
      const isOpen = !menu.classList.contains("hidden");
      menu.classList.toggle("hidden");
      btn.setAttribute("aria-expanded", String(!isOpen));

      if (!isOpen) {
        top.style.transform = "rotate(45deg) translate(3px, 3px)";
        mid.style.opacity = "0";
        bot.style.transform = "rotate(-45deg) translate(3px, -3px)";
      } else {
        top.style.transform = "";
        mid.style.opacity = "";
        bot.style.transform = "";
      }
    });
  }
</script>
