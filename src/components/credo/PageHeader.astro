---
/** PageHeader — Figma node 4:905 */
---

<section class="bg-white w-full">
  <div class="max-w-[1232px] mx-auto px-8 pb-20">
    <!-- Section label -->
    <p class="uppercase text-sm font-medium tracking-[2px] text-dark">
      About Credo
    </p>

    <!-- Yellow divider -->
    <div class="border-t-2 border-accent mt-4"></div>

    <!-- Large centered heading -->
    <h2 class="font-heading font-medium text-[56px] tracking-[-1.4px] text-center text-dark mt-16">
      My approach
    </h2>

    <!-- Centered italic quote -->
    <blockquote class="italic text-[22px] leading-[38.5px] text-gray-text text-center mt-16 max-w-[1000px] mx-auto">
      "I don't sell systems. I recommend the right one for your business."
    </blockquote>

    <!-- Attribution -->
    <div class="flex flex-col items-center mt-5">
      <p class="text-[22px] text-dark text-center">
        Andy Sherborne
      </p>
      <p class="text-sm font-medium text-gray-text uppercase text-center">
        FOUNDER, CREDO
      </p>
    </div>
  </div>
</section>
