---
/** ProcessGrid — Figma node 4:108 */
---

<section class="bg-navy w-full">
  <div class="max-w-[1232px] mx-auto px-8 py-16">
    <!-- Section label -->
    <p class="uppercase text-sm font-medium tracking-[2px] text-white">The numbers</p>
    <div class="border-t border-accent mt-4"></div>

    <!-- Grid: heading left, stats right -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-12 mt-12">
      <!-- Left column: heading -->
      <div>
        <h2 class="font-heading font-medium text-[56px] leading-tight tracking-tight text-white">Numbers that matter</h2>
      </div>

      <!-- Right column: stat rows -->
      <div class="flex flex-col">
        <!-- Stat row 1 -->
        <div class="flex flex-col md:flex-row items-start md:items-center gap-5 py-6 border-b border-accent">
          <h3 class="font-heading font-medium text-[32px] leading-tight tracking-tight text-white flex-1">Typical overpayment on card processing</h3>
          <p class="text-lg leading-relaxed text-white/80 flex-1">Most pub and restaurant owners are paying far more than they should on card processing fees.</p>
          <span class="font-heading font-medium text-[56px] leading-none tracking-tight text-accent text-right shrink-0">20%</span>
        </div>

        <!-- Stat row 2 -->
        <div class="flex flex-col md:flex-row items-start md:items-center gap-5 py-6 border-b border-accent">
          <h3 class="font-heading font-medium text-[32px] leading-tight tracking-tight text-white flex-1">Clients who save in the first month</h3>
          <p class="text-lg leading-relaxed text-white/80 flex-1">Most clients see a reduction in costs within their very first month of switching.</p>
          <span class="font-heading font-medium text-[56px] leading-none tracking-tight text-accent text-right shrink-0">60</span>
        </div>

        <!-- Stat row 3 -->
        <div class="flex flex-col md:flex-row items-start md:items-center gap-5 py-6">
          <h3 class="font-heading font-medium text-[32px] leading-tight tracking-tight text-white flex-1">Of my advice is independent</h3>
          <p class="text-lg leading-relaxed text-white/80 flex-1">I don't take commission from any provider. My only interest is getting you the best deal.</p>
          <span class="font-heading font-medium text-[56px] leading-none tracking-tight text-accent text-right shrink-0">100%</span>
        </div>
      </div>
    </div>
  </div>
</section>
