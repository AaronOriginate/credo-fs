---
/** SingleQuote — Figma node 4:432 */
interface Props {
  label?: string;
  heading?: string;
  quote?: string;
  name?: string;
  source?: string;
  linkText?: string;
  linkHref?: string;
}
const {
  label = "Reviews",
  heading = "What customers say",
  quote = "The best experience since starting my business in 2016. I always recommend Andy to fellow traders.",
  name = "Ron De La Cruz",
  source = "TrustPilot",
  linkText = "See what other customers say",
  linkHref = "/reviews",
} = Astro.props;
---

<section class="w-full">
  <div class="max-w-[1232px] mx-auto px-8 py-16">
    <p class="uppercase text-sm font-medium tracking-[2px] text-dark">{label}</p>
    <div class="border-t border-accent mt-4"></div>

    <h2 class="font-heading font-medium text-[56px] leading-tight tracking-tight text-dark text-center mt-12">{heading}</h2>

    <div class="max-w-md mx-auto mt-12">
      <div class="border-t border-accent"></div>
      <div class="pt-8">
        <div class="flex items-center gap-1 mb-6">
          {[1,2,3,4,5].map(() => (
            <svg class="h-5 w-5 text-accent" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          ))}
        </div>
        <p class="font-heading font-medium text-2xl leading-snug tracking-tight text-dark">&ldquo;{quote}&rdquo;</p>
        <div class="mt-8">
          <p class="text-lg leading-relaxed text-dark">
            <span class="font-semibold">{name}</span> &mdash; {source}
          </p>
        </div>
        {linkHref && (
          <div class="mt-6">
            <a href={linkHref} class="text-sm font-semibold text-dark underline underline-offset-4 hover:text-accent transition-colors">
              {linkText} &rarr;
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
