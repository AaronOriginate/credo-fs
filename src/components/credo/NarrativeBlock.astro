---
/** NarrativeBlock — Figma node 4:38 */
import { href } from '../../lib/nav';
---

<section class="w-full">
  <div class="max-w-[1232px] mx-auto px-8 py-16">
    <!-- Top section: two-column layout -->
    <div class="flex flex-row gap-8 items-start">
      <!-- Left column: image placeholder (~45%) -->
      <div class="w-[45%] shrink-0">
        <div class="bg-navy rounded-lg overflow-hidden aspect-[4/5]">
          <img src={`${import.meta.env.BASE_URL}/images/credo/narrative-person.webp`} alt="Andy Sherborne" width="600" height="668" loading="lazy" class="w-full h-full object-cover" />
        </div>
      </div>

      <!-- Right column: copy + CTA + logos (~55%) -->
      <div class="flex-1 flex flex-col">
        <!-- Intro -->
        <p class="font-heading font-medium text-2xl sm:text-3xl text-dark leading-snug mb-6">
          I'm Andy. I spent twenty years running pubs and hotels before I started looking after the kit that keeps them running.
        </p>
        <!-- Body text -->
        <p class="text-[22px] leading-[38.5px] text-dark">
          Owners don't need more sales calls. They need one person who understands the till, the card machine, the reservations, the funding, the broadband, and how all of it fits together.
        </p>
        <p class="text-base leading-relaxed text-gray-text mt-4">
          Most of the time the kit fails because nobody's actually in charge of the whole thing. The card provider blames the till, the till blames the card, and you're the one stood in the middle of a Saturday night trying to work out who to ring.
        </p>
        <p class="text-base leading-relaxed text-gray-text mt-4">
          That's where I come in. You ring me and I sort it, whether that's quoting for a new setup, fixing what you've already got, or telling you nothing needs changing.
        </p>

        <!-- Yellow CTA button -->
        <a href={href('/contact')} class="bg-accent rounded-lg px-8 py-3 font-semibold text-dark inline-block w-fit mt-6">
          Let's talk
        </a>

        <!-- Trust bar -->
        <div class="mt-12">
          <div class="flex items-center gap-3">
            <div class="flex items-center gap-0.5">
              <svg class="h-5 w-5 text-accent" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
