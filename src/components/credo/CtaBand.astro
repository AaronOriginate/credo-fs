---
/** CtaBand — Figma node 4:275 */
import { href } from '../../lib/nav';
---

<section class="bg-accent w-full">
  <div class="max-w-[1232px] mx-auto px-8 py-24">
    <!-- Large centered heading -->
    <h2 class="font-heading font-medium text-[80px] leading-tight tracking-tight text-dark text-center">Book a free conversation.</h2>

    <!-- Sub-text -->
    <p class="text-lg leading-relaxed text-dark/70 text-center max-w-[700px] mx-auto mt-4">No sales pitch. No commitment. I'll ask about your setup, have a look at what you're paying, and give you an honest answer.</p>

    <!-- Centered button -->
    <div class="flex justify-center mt-8">
      <a href={href('/contact')} class="inline-flex items-center justify-center rounded-lg bg-dark px-8 py-4 font-semibold text-base text-white transition hover:opacity-90">
        Get in Touch
      </a>
    </div>
  </div>
</section>
