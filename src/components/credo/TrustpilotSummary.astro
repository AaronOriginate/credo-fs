---
import { href } from '../../lib/nav';
---
<!-- Figma node: 4:770 — TrustpilotSummary -->
<section class="bg-white w-full">
  <div class="max-w-[1232px] mx-auto px-8 py-24">
    <!-- Section label + yellow divider -->
    <p class="uppercase text-sm font-medium tracking-[2px] text-dark">
      Trustpilot
    </p>
    <div class="border-t border-accent mt-4"></div>

    <!-- Trustpilot table -->
    <div class="flex flex-col lg:flex-row border border-[#ccced3] rounded-lg overflow-hidden mt-12">
      <!-- Left panel — large heading -->
      <div class="lg:w-[35%] p-7 flex items-start">
        <h2 class="font-heading font-medium text-[56px] leading-tight text-dark tracking-[-1.4px]">
          5.0 out of 5 on TrustPilot
        </h2>
      </div>

      <!-- Column: 6 Reviews -->
      <div class="flex-1 border-t lg:border-t-0 lg:border-l border-[#ccced3] p-7 flex flex-col">
        <h3 class="font-heading font-medium text-2xl text-dark tracking-[-0.6px]">
          6 Reviews
        </h3>
        <p class="text-lg leading-relaxed text-dark mt-2">
          Every review is 5 stars. Real feedback from real business owners.
        </p>
        <div class="flex items-end gap-2 mt-auto pt-6">
          <span class="font-heading font-medium text-[56px] leading-[70px] text-dark tracking-[-1.4px]">5.0</span>
          <span class="text-sm text-dark mb-3">/ 5 stars</span>
        </div>
        <a href={href('/reviews')} class="bg-accent rounded-lg px-6 py-3 text-center font-semibold text-[#2d3748] mt-4 inline-block">
          Read Reviews
        </a>
      </div>

      <!-- Column: Verified -->
      <div class="flex-1 border-t lg:border-t-0 lg:border-l border-[#ccced3] p-7 flex flex-col">
        <h3 class="font-heading font-medium text-2xl text-dark tracking-[-0.6px]">
          Verified
        </h3>
        <p class="text-lg leading-relaxed text-dark mt-2">
          All reviews posted independently on TrustPilot by real customers.
        </p>
        <div class="flex items-end gap-2 mt-auto pt-6">
          <span class="font-heading font-medium text-[56px] leading-[70px] text-dark tracking-[-1.4px]">100</span>
          <span class="text-sm text-dark mb-3">% real</span>
        </div>
        <a href={href('/reviews')} class="bg-accent rounded-lg px-6 py-3 text-center font-semibold text-[#2d3748] mt-4 inline-block">
          View Profile
        </a>
      </div>

      <!-- Column: Recent -->
      <div class="flex-1 border-t lg:border-t-0 lg:border-l border-[#ccced3] p-7 flex flex-col">
        <h3 class="font-heading font-medium text-2xl text-dark tracking-[-0.6px]">
          Recent
        </h3>
        <p class="text-lg leading-relaxed text-dark mt-2">
          Latest reviews from December 2025 to February 2026.
        </p>
        <div class="flex items-end gap-2 mt-auto pt-6">
          <span class="font-heading font-medium text-[56px] leading-[70px] text-dark tracking-[-1.4px]">6</span>
          <span class="text-sm text-dark mb-3">reviews</span>
        </div>
        <a href={href('/reviews')} class="bg-accent rounded-lg px-6 py-3 text-center font-semibold text-[#2d3748] mt-4 inline-block">
          See All
        </a>
      </div>
    </div>
  </div>
</section>
