---
/** HeroHome — Figma node 4:6 */
---

<section class="bg-white w-full relative overflow-hidden">
  <!-- Geometric arrow graphic — top left, overlaps nav like consultancy page -->
  <div class="absolute -top-16 left-0 w-[320px] lg:w-[420px] h-auto z-0 pointer-events-none">
    <img
      src="https://credofsdev.wpenginepowered.com/wp-content/uploads/2026/04/credo4.png"
      alt=""
      class="w-full h-auto"
      aria-hidden="true"
    />
  </div>

  <div class="max-w-[1232px] mx-auto px-8 pt-32 sm:pt-40 pb-20 sm:pb-28 flex flex-col items-center relative z-10">
    <!-- Headline -->
    <h1 class="font-heading font-medium text-[48px] sm:text-[64px] lg:text-[92px] leading-tight tracking-[-2.3px] text-center text-dark">
      It's Saturday night, your card machine's gone down, and nobody's picking up the phone.
    </h1>

    <!-- Subtext -->
    <p class="text-lg leading-relaxed text-dark text-center max-w-[600px] mx-auto mt-4">
      You deserve someone who actually answers. And a deal you can understand.
    </p>

    <!-- Buttons -->
    <div class="flex flex-row gap-4 mt-8">
      <a href="/contact" class="bg-accent rounded-lg px-8 py-3 font-semibold text-dark inline-flex items-center gap-1.5">
        Let's have a chat
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
          <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="/consultancy" class="bg-transparent rounded-lg px-8 py-3 font-semibold text-dark">
        See how it works
      </a>
    </div>
  </div>
</section>
