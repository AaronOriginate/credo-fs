---
/** NavyStatement — Figma node 4:33 */
import { href } from '../../lib/nav';
interface Props {
  heading?: string;
  body?: string;
  stats?: { value: string; label: string }[];
  linkText?: string;
  linkHref?: string;
  bg?: 'navy' | 'accent';
}
const {
  heading = "I don't sell for anyone. I work for you.",
  body = "I spent twenty years running pubs and hotels. For the last five I've been looking after the tills, the card machines, the funding, the broadband, the booking systems, all of it. One person on the end of the phone, whether you've got one venue or thirty. That's Credo.",
  stats = [
    { value: "25+", label: "years in hospitality" },
    { value: "1", label: "number to call" },
  ],
  linkText = "Read more about my background",
  linkHref = "/about",
  bg = 'navy',
} = Astro.props;

const isAccent = bg === 'accent';
---

<section class={`${isAccent ? 'bg-accent' : 'bg-navy'} w-full`}>
  <div class="max-w-[1232px] mx-auto px-8 py-24 sm:py-32">
    <h2 class={`font-heading font-medium text-[48px] sm:text-[64px] lg:text-[80px] leading-tight tracking-[-2px] max-w-[990px] ${isAccent ? 'text-dark' : 'text-white'}`}>
      {heading}
    </h2>

    <p class={`text-lg leading-relaxed max-w-[700px] mt-8 ${isAccent ? 'text-dark/70' : 'text-white/80'}`}>
      {body}
    </p>

    {(stats.length > 0 || linkHref) && (
      <div class="flex flex-wrap items-center gap-6 mt-10">
        {stats.map((stat) => (
          <div class={`border rounded-lg px-6 py-4 text-center ${isAccent ? 'border-dark/20' : 'border-white/20'}`}>
            <p class={`font-heading font-medium text-3xl ${isAccent ? 'text-dark' : 'text-accent'}`}>{stat.value}</p>
            <p class={`text-sm mt-1 ${isAccent ? 'text-dark/60' : 'text-white/60'}`}>{stat.label}</p>
          </div>
        ))}
        {linkHref && (
          <a href={href(linkHref)} class={`font-medium hover:underline ml-auto ${isAccent ? 'text-dark' : 'text-accent'}`}>{linkText} &rarr;</a>
        )}
      </div>
    )}
  </div>
</section>
