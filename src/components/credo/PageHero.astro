---
/** PageHero — S02Hero for home (large/centered) + S12/S05 pattern for sub-pages (left-aligned) */
interface Props {
  heading: string;
  subtext?: string;
  eyebrow?: string;
  body?: string[];
  size?: 'large' | 'default';
  bgImage?: string;
}
const {
  heading,
  subtext,
  eyebrow,
  body,
  size = 'default',
  bgImage,
} = Astro.props;

const isLarge = size === 'large';
const bgUrl = bgImage ? `${import.meta.env.BASE_URL}/images/credo/hero-bg-${bgImage}.webp` : null;
---

<!-- Section 02 — Hero | Figma: fileKey=RxueMLDFnpgheWZp4MVk7f nodeId=8:24 -->
<section data-figma-ref="8:24" class={`relative overflow-hidden py-24 sm:py-32 lg:py-40 ${isLarge ? 'bg-white' : 'bg-navy'}`}>
  {bgUrl && (
    <>
      <img
        src={bgUrl}
        alt=""
        class="absolute inset-0 w-full h-full object-cover z-0"
        aria-hidden="true"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-navy/55 z-0" aria-hidden="true"></div>
    </>
  )}

  <!-- Chunky credo graphic, top-left (white variant on navy sub-page hero, navy on home) -->
  <div class="absolute -top-6 sm:-top-8 -left-4 sm:-left-6 w-[100px] sm:w-[130px] lg:w-[170px] h-auto pointer-events-none z-20">
    <img
      src={`${import.meta.env.BASE_URL}/images/credo/${isLarge ? 'hero-credo4.png' : 'hero-credo4-white.png'}`}
      alt=""
      width="626"
      height="744"
      class="w-full h-auto"
      aria-hidden="true"
    />
  </div>

  <div class="max-w-[1232px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    {isLarge ? (
      <!-- Home page: centered, massive -->
      <Fragment>
        {eyebrow && (
          <p class="text-xs uppercase tracking-widest text-gray-text text-center mb-6">{eyebrow}</p>
        )}
        <h1 class="font-heading font-medium text-dark text-center text-4xl sm:text-6xl lg:text-[92px] lg:leading-[1.05] max-w-5xl mx-auto">
          {heading}
        </h1>
        {subtext && (
          <p class="text-dark text-center text-base sm:text-lg max-w-xl mx-auto mt-6">
            {subtext}
          </p>
        )}
      </Fragment>
    ) : (
      <!-- Sub-pages: left-aligned, smaller, 2-col with body text, navy bg -->
      <Fragment>
        {eyebrow && (
          <p class="text-xs uppercase tracking-widest text-white/60 mb-6">{eyebrow}</p>
        )}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-20">
          <h1 class="font-heading font-medium text-white text-3xl sm:text-5xl lg:text-[56px] lg:leading-[1.15] tracking-tight">
            {heading}
          </h1>
          {(body || subtext) && (
            <div class="flex flex-col justify-end">
              {body ? (
                body.map((p, i) => (
                  <p class={`text-white/70 leading-relaxed ${i < body.length - 1 ? 'mb-4' : ''}`}>
                    {p}
                  </p>
                ))
              ) : subtext ? (
                <p class="text-white/70 leading-relaxed">
                  {subtext}
                </p>
              ) : null}
            </div>
          )}
        </div>
      </Fragment>
    )}
  </div>
</section>
