---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Independent hospitality systems advice from Andy Miller. Tills, card machines and connectivity that actually work — with one person to call when they don\u2019t.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="preload" href={`${base}/fonts/Inter-400.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}/fonts/SpaceGrotesk-600.woff2`} as="font" type="font/woff2" crossorigin />
  </head>
  <body class="font-body text-dark antialiased">
    <main><slot /></main>
  </body>
</html>
